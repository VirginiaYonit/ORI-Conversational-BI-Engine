flowchart TB

%% ===== STYLES (Blueprint look) =====
classDef deterministic fill:#e8f0ff,stroke:#1f4ed8,stroke-width:2px,color:#0b1f4d;
classDef boundary fill:#eef9f3,stroke:#15803d,stroke-width:2px,color:#052e16;
classDef llm fill:#f8f9fa,stroke:#6b7280,stroke-width:1.5px,color:#111827,stroke-dasharray: 5 5;
classDef governance fill:#fff7ed,stroke:#c2410c,stroke-width:2px,color:#431407;
classDef output fill:#fdf4ff,stroke:#86198f,stroke-width:2px,color:#3b0764;

%% ===== INPUT =====
U[User Question]:::governance

%% ===== CORE =====
subgraph CORE["Deterministic Core<br/>(Source of Truth)"]
  I[Intent Detection<br/>qa_intent.py]:::deterministic
  C[Analytical Context<br/>dataset + KPI focus]:::deterministic
  P[Profiling & Quality<br/>profiling.py]:::deterministic
  K[KPI Ranking<br/>kpi_selector.py]:::deterministic

  A[Deterministic Analytics<br/>trend · growth · correlations · divergence]:::deterministic
  AGG[Deterministic Aggregations<br/>sum · mean · count · min/max · YoY% · PoP]:::deterministic
end

%% ===== GOVERNANCE =====
subgraph GOV["Governance & Constraints"]
  G1[Context validity<br/>in / out of scope]:::governance
  G2[Aggregation rule<br/>aggregations are Python-only]:::governance
  G3[Operational limits<br/>e.g. divergence ≤ 2 KPI]:::governance
  G4[Canonical messages<br/>system_messages.py]:::governance
end

%% ===== INSIGHT =====
subgraph IE["Insight Engine<br/>(Interpretation Boundary)"]
  B1[Select admissible insights]:::boundary
  B2[Attach warnings & limits]:::boundary
  B3[Prepare structured facts bundle]:::boundary
end

%% ===== LLM =====
subgraph LLM["LLM Layer (Optional)"]
  L1[OpenAI client]:::llm
  L2[Gemini client]:::llm
end

%% ===== OUTPUT =====
subgraph OUT["Output Layer"]
  O1[Text Answer]:::output
  O2[Mini-report PDF]:::output
end

%% ===== FLOW =====
U --> I --> C --> P --> K

K --> A
K --> AGG

A --> G1
AGG --> G2
A --> G3

G1 --> B1
G2 --> B2
G3 --> B2
G4 --> B2

A --> B3
AGG --> B3

B1 --> O1
B2 --> O1

B3 --> L1
B3 --> L2
L1 --> O1
L2 --> O1

O1 --> O2
